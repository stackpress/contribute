{
  "private": true,
  "projects": {
    "lib": {
      "repository": "https://github.com/stackpress/lib.git",
      "root": "../lib",
      "build": "yarn lib build",
      "test": "yarn lib test",
      "examples": [],
      "publish": [ "." ]
    },
    "idea": {
      "repository": "https://github.com/stackpress/idea.git",
      "root": "../idea",
      "build": "yarn idea build",
      "test": "yarn idea test",
      "examples": [ "./example" ],
      "publish": [ 
        "./packages/idea-parser",
        "./packages/idea-transformer",
        "./packages/idea"
      ]
    },
    "ingest": {
      "repository": "https://github.com/stackpress/ingest.git",
      "root": "../ingest",
      "build": "yarn ingest build",
      "test": "yarn ingest test",
      "examples": [ 
        "./examples/with-entries",
        "./examples/with-google",
        "./examples/with-handlebars",
        "./examples/with-http",
        "./examples/with-imports",
        "./examples/with-lambda",
        "./examples/with-netlify",
        "./examples/with-plugins",
        "./examples/with-vercel",
        "./examples/with-whatwg" 
      ],
      "publish": [ "./ingest" ]
    },
    "inquire": {
      "repository": "https://github.com/stackpress/inquire.git",
      "root": "../inquire",
      "build": "yarn inquire build",
      "test": "yarn inquire test",
      "examples": [ 
        "./examples/with-crdb",
        "./examples/with-mysql2",
        "./examples/with-neon",
        "./examples/with-pg",
        "./examples/with-pglite",
        "./examples/with-sqlite3",
        "./examples/with-supabase"
      ],
      "publish": [ 
        "./packages/inquire",
        "./packages/inquire-mysql2",
        "./packages/inquire-pg",
        "./packages/inquire-pglite",
        "./packages/inquire-sqlite3"
      ]
    },
    "reactus": {
      "repository": "https://github.com/stackpress/reactus.git",
      "root": "../reactus",
      "build": "yarn reactus build",
      "test": "yarn reactus test",
      "examples": [ 
        "./examples/with-express",
        "./examples/with-fastify",
        "./examples/with-hapi",
        "./examples/with-http",
        "./examples/with-koa",
        "./examples/with-nest",
        "./examples/with-plugin",
        "./examples/with-restify",
        "./examples/with-tailwind",
        "./examples/with-unocss" 
      ],
      "publish": [ "./reactus" ]
    },
    "stackpress": {
      "repository": "https://github.com/stackpress/stackpress.git",
      "root": "../stackpress",
      "build": "yarn stackpress build",
      "test": "",
      "examples": [ 
        "./templates/blog",
        "./templates/store",
        "./templates/website"
      ],
      "publish": [ "./stackpress" ]
    },
    "frui": {
      "repository": "https://github.com/OSSPhilippines/frui.git",
      "root": "../frui",
      "build": "yarn frui build",
      "test": "yarn frui test",
      "examples": [],
      "publish": [ "." ]
    },
    "r22n": {
      "repository": "https://github.com/OSSPhilippines/r22n.git",
      "root": "../r22n",
      "build": "yarn r22n build",
      "test": "yarn r22n test",
      "examples": [],
      "publish": [ "." ]
    }
  },
  "scripts": {
    "lib": "yarn --cwd ../lib",
    "idea": "yarn --cwd ../idea",
    "ingest": "yarn --cwd ../ingest",
    "inquire": "yarn --cwd ../inquire",
    "reactus": "yarn --cwd ../reactus",
    "stackpress": "yarn --cwd ../stackpress",
    "frui": "yarn --cwd ../ossph/frui",
    "r22n": "yarn --cwd ../ossph/r22n",
    "clone": "yarn tsenv tsx scripts/clone.ts",
    "connect": "yarn tsenv tsx scripts/connect.ts",
    "modules": "yarn tsenv tsx scripts/modules.ts",
    "pull": "yarn tsenv tsx scripts/pull.ts",
    "push": "yarn tsenv tsx scripts/push.ts",
    "sync": "yarn tsenv tsx scripts/sync.ts",
    "update": "yarn tsenv tsx scripts/update.ts",
    "tsenv": "NODE_OPTIONS=\"--disable-warning=ExperimentalWarning --experimental-loader @istanbuljs/esm-loader-hook\""
  },
  "devDependencies": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/node": "25.3.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "common": {
    "@istanbuljs/esm-loader-hook": "0.3.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "chai": "4.5.0",
    "mocha": "10.8.2",
    "mocha-lcov-reporter": "1.3.0",
    "nyc": "17.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ts-mocha": "10.0.0",
    "ts-node": "10.9.2",
    "ts-morph": "27.0.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "unocss": "66.6.6"
  }
}